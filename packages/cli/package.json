{
  "name": "remb-cli",
  "version": "0.1.0",
  "description": "CLI for Remb — persistent memory layer for AI coding sessions",
  "type": "module",
  "bin": {
    "remb": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "context",
    "ai",
    "cli",
    "mcp",
    "coding-assistant"
  ],
  "license": "MIT",
  "homepage": "https://useremb.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/samie105/remb.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/samie105/remb/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "glob": "^11.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
